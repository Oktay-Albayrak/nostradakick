{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "========= Pour la BDD prisma =========": "===========================",
    "db:seed": "ts-node prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:reset": "npm run db:migrate:reset && npm run db:seed",
    "db:clean:matches": "ts-node prisma/cleanMatches.ts",
    "========= Pour le dev =========": "===========================",
    "dev": "node --watch --env-file=.env index.ts",
    "sync": "ts-node src/jobs/sync.now.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "========= Pour la prod =========": "===========================",
    "build": "prisma generate",
    "start": "node index.ts",
    "postinstall": "prisma generate"
  },
