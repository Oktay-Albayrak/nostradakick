generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PredictionValue {
  HOME // "1"
  DRAW // "N"
  AWAY // "2"
}

enum PredictionStatus {
  PENDING
  WON
  LOST
  CANCELLED
}

enum MatchStatus {
  SCHEDULED
  TIMED
  IN_PLAY
  PAUSED
  FINISHED
  SUSPENDED
  POSTPONED
  CANCELLED
  AWARDED
}

enum UserRole {
  MEMBER
  ADMIN
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  username      String   @unique @db.VarChar(50)
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.Text
  role          UserRole @default(MEMBER)
  avatar_url    String?  @db.Text // Optionnel pour éviter les erreurs à l'inscription
  created_at    DateTime @default(now()) @db.Timestamptz()
  updated_at    DateTime @updatedAt @db.Timestamptz()

  stats       UserStat?    @relation("UserToUserStat")
  predictions Prediction[] @relation("UserToPrediction")
  refresh_token RefreshToken[] @relation("UserToRefreshToken")

  @@map("user")
}

model UserStat {
  user         User   @relation("UserToUserStat", fields: [user_id], references: [id], onDelete: Cascade)
  user_id      String @id @db.Uuid
  wins_count   Int    @default(0)
  losses_count Int    @default(0)
  best_streak  Int    @default(0)

  @@map("user_stat")
}

model Competition {
  id         String   @id @default(uuid()) @db.Uuid
  api_id     Int?     @unique
  name       String   @unique @db.Text
  code       String?  @db.VarChar(10)
  emblem_url String   @db.Text
  country    String   @db.Text
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @updatedAt @db.Timestamptz()

  teams     CompetitionTeam[]
  matches   Match[]
  standings Standing[]

  @@map("competition")
}

model Team {
  id         String   @id @default(uuid()) @db.Uuid
  api_id     Int?     @unique
  name       String   @unique @db.Text
  short_name String?  @db.Text
  tla        String   @db.VarChar(6)
  crest_url  String   @db.Text
  country    String   @db.Text
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @updatedAt @db.Timestamptz()

  competitions CompetitionTeam[]
  home_matches Match[]           @relation("home_team")
  away_matches Match[]           @relation("away_team")
  standings    Standing[]

  @@map("team")
}

model CompetitionTeam {
  team           Team        @relation(fields: [team_id], references: [id])
  team_id        String      @db.Uuid
  competition    Competition @relation(fields: [competition_id], references: [id])
  competition_id String      @db.Uuid
  created_at     DateTime    @default(now()) @db.Timestamptz
  updated_at     DateTime    @updatedAt @db.Timestamptz

  @@id([team_id, competition_id])
  @@map("competition_team")
}

model Standing {
  id             String   @id @default(uuid()) @db.Uuid
  rank           Int
  team_id        String   @db.Uuid
  competition_id String   @db.Uuid
  updated_at     DateTime @updatedAt @db.Timestamptz

  team        Team        @relation(fields: [team_id], references: [id])
  competition Competition @relation(fields: [competition_id], references: [id])

  @@unique([team_id, competition_id])
  @@map("standing")
}

model Match {
  id             String       @id @default(uuid()) @db.Uuid
  api_id         Int?         @unique
  date           DateTime     @db.Timestamptz
  status         MatchStatus  @default(SCHEDULED)
  home_score     Int?
  away_score     Int?
  home_team      Team         @relation("home_team", fields: [home_team_id], references: [id])
  home_team_id   String       @db.Uuid
  away_team      Team         @relation("away_team", fields: [away_team_id], references: [id])
  away_team_id   String       @db.Uuid
  competition    Competition  @relation(fields: [competition_id], references: [id])
  competition_id String       @db.Uuid
  is_featured    Boolean      @default(false)
  featured_name  String?      @db.Text
  popularity     Int          @default(0) // Nombre de pronostics
  created_at     DateTime     @default(now()) @db.Timestamptz
  updated_at     DateTime     @updatedAt @db.Timestamptz
  predictions    Prediction[]

  @@map("match")
}

model Prediction {
  id               String           @id @default(uuid()) @db.Uuid
  prediction_value PredictionValue
  status           PredictionStatus @default(PENDING)
  user             User             @relation("UserToPrediction", fields: [user_id], references: [id], onDelete: Cascade)
  user_id          String           @db.Uuid
  match            Match            @relation(fields: [match_id], references: [id])
  match_id         String           @db.Uuid
  created_at       DateTime         @default(now()) @db.Timestamptz
  updated_at       DateTime         @updatedAt @db.Timestamptz

  @@unique([user_id, match_id])
  @@map("prediction")
}

model RefreshToken {
  id          String   @id @default(uuid()) @db.Uuid
  token       String   @db.Text

  created_at  DateTime @default(now()) @db.Timestamptz
  expires_at  DateTime @updatedAt @db.Timestamptz

  user        User     @relation("UserToRefreshToken", fields: [user_id], references: [id])
  user_id     String   @db.Uuid

  @@map("refresh_token")
}
