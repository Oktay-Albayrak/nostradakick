Cookie: accessToken=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI4MmU0YmNjMC1mZGRhLTRiYmItYjczOS01ZjQwNzk5ZDVkODciLCJ1c2VyUm9sZSI6IkFETUlOIiwiaWF0IjoxNzY5MDAxNDE5LCJleHAiOjE3NjkwMDUwMTl9.aBAD6R-2sV9OwysGa9plexM9Dz9sIRUf8l-ZAcdiar4

### POST /api/predictions - Sans auth (401) | Créer pour autre (403) | Créer pour soi (200)
POST http://localhost:4000/api/predictions
Content-Type: application/json
Cookie: accessToken=VOTRE_TOKEN_MEMBER_ICI

{
  "user_id": "VOTRE_USER_ID_ICI",
  "match_id": "28549d58-221f-4430-b5a8-a7c4327d25aa",
  "prediction_value": "HOME"
}

### DELETE /api/predictions/:id - Sans auth (401) | Supprimer autre (403) | Supprimer soi/ADMIN (204)
DELETE http://localhost:4000/api/predictions/023e8d45-cb76-4fe1-ad01-0f4cd04ff0ee
Cookie: accessToken=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI4MmU0YmNjMC1mZGRhLTRiYmItYjczOS01ZjQwNzk5ZDVkODciLCJ1c2VyUm9sZSI6IkFETUlOIiwiaWF0IjoxNzY5MDAxNDE5LCJleHAiOjE3NjkwMDUwMTl9.aBAD6R-2sV9OwysGa9plexM9Dz9sIRUf8l-ZAcdiar4
